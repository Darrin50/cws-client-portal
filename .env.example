# Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Database (PostgreSQL via Neon)
DATABASE_URL=postgresql://username:password@host/database_name

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key_here

# Pusher (Real-time updates)
NEXT_PUBLIC_PUSHER_APP_KEY=your_pusher_app_key_here
PUSHER_APP_ID=your_pusher_app_id_here
PUSHER_SECRET=your_pusher_secret_here

# Upload Thing
UPLOADTHING_SECRET=your_uploadthing_secret_here
NEXT_PUBLIC_UPLOADTHING_APP_ID=your_uploadthing_app_id_here

# Screenshot API (Optional)
SCREENSHOTONE_API_KEY=your_screenshotone_api_key_here

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
